# ============================================
# Skyrim Mod Development .gitignore
# ============================================

# Build artifacts and binary outputs
/.bin/
/.lib/
/build/
/out/
/dist/
/target/

# CMake generated files
/CMakeCache.txt
/CMakeFiles/
/cmake_install.cmake
/Makefile
/compile_commands.json

# Visual Studio / MSBuild
*.vcxproj.user
*.vcxproj.filters
*.sln.cache
*.suo
*.user
*.aps
*.pch
*.vsidx
*.vspscc
*.tmp
*.log
*.tlog
*.lastbuildstate
*.unsuccessfulbuild
.vs/
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

# Windows OS
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
*.bak
*.backup
*.orig
*.rej

# IDE and editor files
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/
.vscode/ !.vscode/extensions.json

# Logs and debugging
*.log
*.dmp
*.mdmp
logs/
debug.log
release.log

# Package management
node_modules/
.vcpkg/
packages/

# Skyrim specific
# Ignore extern directories (contains CommonLibSSE and dependencies) in all mod projects
*/extern/
# Ignore shared folders
/Shared/
# But keep the framework headers if they're in the repo root
!/SKSEMenuFramework/

# Backup files
*.bak
*.old
*.orig

# Archive files (if not intended to be committed)
/*.zip
/*.7z
/*.rar
/*.tar.gz

# Documentation generated files (if any)
/docs/build/
/api-docs/

# Test outputs
test-results/
coverage/

# Local configuration (create templates instead)
config.local.*
settings.local.*
*.local
