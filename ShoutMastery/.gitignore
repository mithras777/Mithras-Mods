# ============================================
# Skyrim Mod Development .gitignore
# ============================================

# Build artifacts and binary outputs
/.bin/
/.lib/
/build/
/out/
/dist/
/target/

# CMake generated files
/CMakeCache.txt
/CMakeFiles/
/cmake_install.cmake
/Makefile
/compile_commands.json

# Visual Studio / MSBuild
*.vcxproj.user
*.vcxproj.filters
*.sln.cache
*.suo
*.user
*.aps
*.pch
*.vsidx
*.vspscc
*.tmp
*.log
*.tlog
*.lastbuildstate
*.unsuccessfulbuild
.vs/
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

# IDE and editor files
.idea/
.vscode/
!.vscode/extensions.json

# Temporary and OS files
*.tmp
*.temp
*.swp
*.swo
*~
Thumbs.db
[Dd]esktop.ini

# Skyrim specific extern/shared folders
/ShoutMastery/extern/
*/extern/
/Shared/
!/SKSEMenuFramework/
